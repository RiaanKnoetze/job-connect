{
  "name": "job-connect",
  "version": "1.0.0",
  "description": "Job Connect WordPress plugin",
  "scripts": {
    "build": "wp-scripts build --config webpack.config.js && npm run build:css",
    "build:css": "tailwindcss -i src/frontend/frontend.css -o assets/css/frontend.css --minify",
    "start": "wp-scripts start --config webpack.config.js",
    "watch:css": "tailwindcss -i src/frontend/frontend.css -o assets/css/frontend.css --watch"
  },
  "devDependencies": {
    "@wordpress/scripts": "^27.0.0",
    "tailwindcss": "^3.4.19"
  }
}
